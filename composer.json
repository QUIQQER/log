      "homepage": "https://www.pcsg.de",
      "role": "Developer"
    }
  ],
  "support": {
    "email": "support@pcsg.de"
  },
  "require": {
    "php": "^8",
    "ext-zip": "*",
    "quiqqer\/core": "^2",
    "monolog\/monolog": "^3",
